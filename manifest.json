{
  "manifest_version": 3,
  "name": "Chrome Tabbed Floating Notepad",
  "version": "0.0.7.14",
  "description": "A floating, draggable, resizable lined notepad.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "Authur": "Pramod Chaudhary",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Notepad"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}